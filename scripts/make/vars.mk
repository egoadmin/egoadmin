APPNAME := egoadmin
PROJECT := egoadmin
BUILD_TAG := 0.0.1
BUILD_VERSION := 0.0.1
BUILD_USER := $(shell git config user.name)
BUILD_HOST := $(shell hostname)
BUILD_TIME := $(shell date +%Y-%m-%d_%H:%M:%S)

LAST_TAG := $(shell git describe --abbrev=0 --tags HEAD^ 2>/dev/null)
