SERVICES ?= idgen user gateway
SERVICE ?=
DOCKER_REGISTRY ?= egoadmin
DOCKER_TAG ?= latest
DOCKER_COMPOSE ?= docker compose
DEV_COMPOSE_PROJECT ?= $(PROJECT)
