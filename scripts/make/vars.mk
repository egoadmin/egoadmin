GO_TOOL_BIN := $(shell go env GOBIN)
ifeq ($(GO_TOOL_BIN),)
GO_TOOL_BIN := $(shell go env GOPATH)/bin
endif
export PATH := $(GO_TOOL_BIN):$(shell go env GOPATH)/bin:$(PATH)

MAKE_CMD := $(MAKE)
