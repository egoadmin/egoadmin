# Image settings.
DOCKER_REGISTRY=egoadmin
DOCKER_TAG=latest

# MySQL settings. These defaults are for local single-machine deployment only.
MYSQL_ROOT_PASSWORD=egoadmin
MYSQL_USER=egoadmin
MYSQL_PASSWORD=egoadmin
MYSQL_IDGEN_DATABASE=egoadmin_idgen
MYSQL_USER_DATABASE=egoadmin_user
MYSQL_GATEWAY_DATABASE=egoadmin_gateway
MYSQL_DTM_DATABASE=egoadmin_dtm
MYSQL_GATEWAY_PORT=3306
MYSQL_USER_PORT=3307
MYSQL_IDGEN_PORT=3308
MYSQL_DTM_PORT=3309

# Redis settings.
REDIS_AOF_ENABLED=yes
REDIS_PASSWORD=egoadmin
REDIS_GATEWAY_PORT=6379
REDIS_USER_PORT=6380

# MinIO settings.
MINIO_ROOT_USER=egoadmin
MINIO_ROOT_PASSWORD=egoadmin123
STORAGE_BUCKET=egoadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=19001

# CDN/image processing settings.
CDN_SIGN_SECRET=deploy-egoadmin-cdn-sign-secret
IMAGE_PROCESSOR_SECRET=deploy-egoadmin-image-processor-secret
IMAGE_PROCESSOR_PORT=2853

# Meilisearch settings.
MEILI_ENV=production
MEILI_MASTER_KEY=deploy-egoadmin-meili-key
MEILI_LOG_LEVEL=INFO
MEILI_PORT=7700

# DTM settings.
DTM_HTTP_PORT=36789
DTM_GRPC_PORT=36790
DTM_STORE_HOST=mysql-dtm
DTM_STORE_PORT=3306
DTM_STORE_USER=egoadmin
DTM_STORE_PASSWORD=egoadmin
DTM_STORE_DB=egoadmin_dtm
DTM_MICRO_SERVICE_TARGET=etcd://etcd:2379/egoadmin-dtm
DTM_MICRO_SERVICE_ENDPOINT=dtm:36790

# Service ports.
GATEWAY_HTTP_PORT=9001
GATEWAY_GRPC_PORT=9002
GATEWAY_GOVERNOR_PORT=9003
USER_HTTP_PORT=9101
USER_GRPC_PORT=9102
USER_GOVERNOR_PORT=9103
IDGEN_HTTP_PORT=9201
IDGEN_GRPC_PORT=9202
IDGEN_GOVERNOR_PORT=9203

# Application secrets. Override in real deployments.
EGOADMIN_ADMIN_PASSWORD=123456
EGOADMIN_ROOT_PASSWORD=
EGOADMIN_JWT_SIGN_KEY=deploy-egoadmin-jwt-sign-key
